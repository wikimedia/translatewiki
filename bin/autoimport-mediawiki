#!/bin/bash
set -o nounset -o pipefail -o errexit

DIRSCRIPT=$(dirname "$(readlink -f "$0")")
. /etc/wikisettings
# shellcheck source=bin/synclock
. "$DIRSCRIPT/synclock"

SCRIPT="$WIKIDIR/extensions/Translate/scripts/importExternalTranslations.php"
NAME=mediawiki

# Needed for list-projects to know which repoconfig.yaml to read
cd "$AUTOIMPORT_DIR"

set +o errexit

# Note that repo update command uses parallelization
php "$DIRSCRIPT/../repong/repong.php" list-projects | grep ^mediawiki | xargs -n1 "$DIRSCRIPT/repo" update
UPDATE_CODE=$?

OUTPUT=$(php "$WIKISCRIPT" "$SCRIPT" --name "$NAME" --group=core,ext-*,mediawiki*)
IMPORT_CODE=$?

set -o errexit

if [[ -n "$OUTPUT" ]]
then
	echo "$OUTPUT"
	echo "$OUTPUT" | xargs -l "$DIRSCRIPT/udpcast"
fi

if (( UPDATE_CODE || IMPORT_CODE ))
then
	"$DIRSCRIPT/udpcast" "Errors in autoimport-mediawiki. Please check the logs."
	exit 1
fi
